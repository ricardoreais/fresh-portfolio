{
  "name": "fresh-portfolio",
  "version": "2.5.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration production --base-href /",
    "deploy": "ngh --dir=dist/fresh-portfolio",
    "test": "ng test --no-watch",
    "lint": "ng lint",
    "cy:open": "concurrently \"ng serve\" \"cypress open\"",
    "cy:run": "concurrently \"ng serve\" \"cypress run\""
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/localize": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ng-bootstrap/ng-bootstrap": "^21.0.0",
    "@popperjs/core": "^2.11.6",
    "bootstrap": "^5.3.0",
    "core-js": "^3.49.0",
    "hammerjs": "^2.0.8",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.0",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "concurrently": "^10.0.0",
    "cypress": "latest",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "http-proxy-middleware": "3.0.7",
    "uuid": "11.1.1",
    "esbuild": "0.28.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "core-js@3.49.0": true,
    "cypress@15.18.0": true,
    "esbuild@0.28.1": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
